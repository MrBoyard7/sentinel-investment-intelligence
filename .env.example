# ---------------------------------------------------------------------------
# Sentinel configuration
# Copy this file to ".env" and fill in the values you have available.
# Sentinel is designed to run in DEMO_MODE with no credentials at all.
# ---------------------------------------------------------------------------

# Set to "false" once real sources / API keys are configured.
# In demo mode, collectors read from local fixtures and the AI scorer falls
# back to a deterministic heuristic instead of calling OpenAI.
DEMO_MODE=true

# --- AI scoring -------------------------------------------------------------
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- Storage ------------------------------------------------------------
DATABASE_PATH=data/db/sentinel.sqlite3

# --- Email alerts (SMTP) --------------------------------------------------
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
ALERT_EMAIL_FROM=
ALERT_EMAIL_TO=

# --- Slack alerts ----------------------------------------------------------
SLACK_WEBHOOK_URL=

# --- SMS alerts (Twilio REST API, no SDK dependency required) --------------
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
ALERT_SMS_TO=

# --- Dashboard ---------------------------------------------------------
DASHBOARD_HOST=127.0.0.1
DASHBOARD_PORT=5000

# --- Alert thresholds --------------------------------------------------
# Importance score (1-5) at or above which an immediate alert is sent.
IMMEDIATE_ALERT_SCORE=4
